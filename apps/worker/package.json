{
  "name": "@extractionstack/worker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/apps/worker/src/main.js",
    "dev": "ts-node --project tsconfig.json src/main.ts",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "test:e2e": "echo 'worker behavior covered by integration tests'"
  },
  "dependencies": {
    "@extractionstack/shared": "workspace:*",
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@prisma/client": "^5.10.0",
    "bullmq": "^5.34.0",
    "ioredis": "^5.4.1",
    "ipaddr.js": "^2.2.0",
    "playwright": "^1.42.0",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0",
    "vitest": "^1.6.1"
  }
}
