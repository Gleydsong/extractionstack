{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2022", "DOM"],
    "rootDir": "../..",
    "outDir": "./dist",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "useDefineForClassFields": false,
    "verbatimModuleSyntax": false,
    "esModuleInterop": true,
    "target": "ES2022",
    "baseUrl": ".",
    "paths": {
      "@extractionstack/shared": ["../../packages/shared/src/index.ts"]
    }
  },
  "include": ["src/**/*", "../api/src/extract/**/*", "../api/src/common/**/*", "../api/src/prisma/**/*"]
}
