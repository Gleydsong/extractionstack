# --- API ---
API_PORT=3001
API_BASE_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:5173

# --- Auth0 (backend) ---
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://api.extractionstack.local
AUTH0_ISSUER=https://your-tenant.us.auth0.com/

# --- Auth0 (frontend) ---
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=replace-me
VITE_AUTH0_AUDIENCE=https://api.extractionstack.local
VITE_AUTH0_REDIRECT_URI=http://localhost:5173/callback

# --- Database (Prisma) ---
DATABASE_URL=postgresql://extractionstack:extractionstack@localhost:5432/extractionstack?schema=public
REDIS_URL=redis://localhost:6379

# --- Dev mode (local only; API refuses boot if AUTH_DEV_MODE=true with NODE_ENV=production) ---
AUTH_DEV_MODE=true
VITE_AUTH_DEV_MODE=true

# --- Crawler ---
CRAWLER_TIMEOUT_MS=25000
CRAWLER_MAX_REDIRECTS=5
CRAWLER_MAX_HTML_BYTES=5242880
CRAWLER_MAX_RESPONSES=1000
WORKER_CONCURRENCY=2
THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT=10

# Optional bearer token protecting /metrics in production (minimum 16 chars)
METRICS_TOKEN=
LOG_LEVEL=info

# --- LLM runtime ---
# Required in production: base64 for exactly 32 random bytes. Never commit a real key.
LLM_CREDENTIAL_MASTER_KEY=
LLM_CREDENTIAL_KEY_VERSION=local-v1
LLM_OPENAI_BASE_URL=https://api.openai.com/v1
LLM_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
LLM_OPENAI_MODEL_ALLOWLIST=gpt-5-mini
LLM_GEMINI_MODEL_ALLOWLIST=gemini-2.5-flash
LLM_TIMEOUT_MS=30000
LLM_MAX_INPUT_TOKENS=32000
LLM_MAX_OUTPUT_TOKENS=4096
LLM_MAX_COST_MINOR_UNITS=500
# Required in production. Rates are decimal strings in provider billing micros per 1M tokens.
LLM_PRICING_VERSION=unconfigured-v1
LLM_PRICING_CATALOG_JSON=[]

# Gemini OAuth (all four values are required to enable the flow)
LLM_GEMINI_OAUTH_CLIENT_ID=
LLM_GEMINI_OAUTH_CLIENT_SECRET=
LLM_GEMINI_OAUTH_PROJECT_ID=
LLM_GEMINI_OAUTH_REDIRECT_URIS=http://localhost:3001/api/ai/connections/GEMINI/oauth/callback
