{
  "name": "extractionstack",
  "version": "0.1.0",
  "private": true,
  "description": "Analyze a live URL and produce a structured tech-stack report.",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel --filter=@extractionstack/api --filter=@extractionstack/worker --filter=@extractionstack/llm-worker --filter=@extractionstack/web run dev",
    "dev:api": "pnpm --filter @extractionstack/api run dev",
    "dev:web": "pnpm --filter @extractionstack/web run dev",
    "dev:worker": "pnpm --filter @extractionstack/worker run dev",
    "dev:llm-worker": "pnpm --filter @extractionstack/llm-worker run dev",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm --filter @extractionstack/shared build && pnpm --filter @extractionstack/llm-core build && pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:e2e": "pnpm test:e2e:http && pnpm test:e2e:browser",
    "test:e2e:http": "pnpm --filter @extractionstack/api test:e2e",
    "test:e2e:browser": "playwright test",
    "test:smoke:providers": "node -e \"if(process.env.RUN_REAL_PROVIDER_SMOKE!=='true')process.exit(1)\" && node scripts/real-provider-smoke.mjs",
    "verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "prisma:generate": "pnpm --filter @extractionstack/api run prisma:generate",
    "prisma:migrate": "pnpm --filter @extractionstack/api run prisma:migrate",
    "prisma:migrate:deploy": "pnpm --filter @extractionstack/api run prisma:migrate:deploy",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\""
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.0"
  }
}
